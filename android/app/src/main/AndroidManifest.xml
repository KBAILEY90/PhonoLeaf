<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Portrait-locked: rotating re-flows the epub into a different column
             layout, which changes the page count/positions under the reader and
             made a page-end auto-advance jump backwards several pages. The UI is
             portrait-first anyway (matches manifest.json's "orientation").
             Supporting landscape properly means re-anchoring to the current CFI
             and resetting the page-turn corrector on resize — a later job. -->
        <activity
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth return deep link (system-browser sign-in). Scheme is the
                 REVERSED Android OAuth client id (Cloud Console > Credentials
                 > PhonoLeaf Android (debug)). If that client is ever
                 recreated, update this AND CONFIG.ANDROID_CLIENT_ID together. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.googleusercontent.apps.871446308528-am1hi0il8670867uvai80q4d18fduee6" />
            </intent-filter>

        </activity>

        <!-- Keeps the WebView's <audio> sentence-chain alive when backgrounded /
             screen off. See PlaybackService.kt. exported=false: only we start it. -->
        <service
            android:name=".PlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Background/lock-screen audio (@jofr/capacitor-media-session runs a
         foreground service). The plugin declares FOREGROUND_SERVICE, but on
         Android 14+ (targetSdk 36) starting a mediaPlayback FGS also needs
         FOREGROUND_SERVICE_MEDIA_PLAYBACK or it crashes; POST_NOTIFICATIONS
         (Android 13+) lets the media notification show. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>
